# ── AI Provider ───────────────────────────────────────────────────────────────
# Which provider to use: "anthropic" (default) or "google"
AI_PROVIDER=anthropic

# Model for question parameter generation (fast/cheap)
# Anthropic default: claude-haiku-4-5-20251001
# Google default:    gemini-2.0-flash
QUESTION_GEN_MODEL=claude-haiku-4-5-20251001

# Model for session analysis (more capable)
# Anthropic default: claude-sonnet-4-6
# Google default:    gemini-2.0-flash
ANALYSIS_MODEL=claude-sonnet-4-6

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-google-ai-key-here

# ── App Config ────────────────────────────────────────────────────────────────
QUESTION_CACHE_TTL_SECONDS=3600
MIN_QUESTIONS_PER_SESSION=5
MAX_QUESTIONS_PER_SESSION=20

# ── Usage Limits ───────────────────────────────────────────────────────────────
# Tier controls daily session limits and question count options.
# Values: "free" (default), "paid", "dev" (unlimited — local dev only)
DEFAULT_TIER=free
